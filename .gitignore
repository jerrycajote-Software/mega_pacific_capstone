
# MEGA PACIFIC - Root .gitignore
# Covers: Node.js backend, React/Vite frontend, Prisma, OS/editor
# ============================================================

#  Environment Variables (NEVER commit these) 
.env
.env.*
!.env.example
*.env

#  Node / NPM 
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

#  Build Outputs 
dist/
dist-ssr/
build/
out/
.output/

#  Vite / Frontend 
*.local
.vite/

#  Prisma 
# Generated Prisma client (can be regenerated with `prisma generate`)
backend/generated/
backend/prisma/generated/

#  Database 
Database/
*.sql
*.dump
*.db
*.sqlite
*.sqlite3

#  OS & System Files 
.DS_Store
Thumbs.db
desktop.ini

#  Editor / IDE 
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

#  Misc / Personal 
MyLearning/
*.md.bak
*.tmp
*.cache
